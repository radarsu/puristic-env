{
    "name": "@puristic/root",
    "version": "0.0.0",
    "private": true,
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/puristic-env.git"
    },
    "scripts": {
        "build": "turbo run build",
        "test": "turbo run test",
        "diff:stat": "git diff HEAD --shortstat",
        "clear": "find . \\( -name 'node_modules' -or -name '.cache' -or -name 'dist' -or -name '.turbo' -or -name 'pnpm-lock.yaml' \\) -exec rm -rf '{}' +",
        "cache:clear": "find . \\( -name '.cache' -or -name 'dist' -or -name '.turbo' \\) -exec rm -rf '{}' +",
        "deps:up": "pnpm --recursive update --latest",
        "libs:watch": "nice -n 15 tsc --build --watch --preserveWatchOutput tsconfig.libs.json",
        "dev": "code /home/radarsu/radarsu/repositories/confederation/_libs/vscode"
    },
    "devDependencies": {
        "@biomejs/biome": "catalog:",
        "@types/node": "catalog:",
        "knip": "catalog:",
        "tslib": "catalog:",
        "turbo": "catalog:",
        "typescript": "catalog:"
    },
    "engines": {
        "node": "24.14.0",
        "pnpm": "11.1.2"
    },
    "packageManager": "pnpm@11.1.2"
}
