{
    "name": "env",
    "version": "0.0.0",
    "license": "MIT",
    "type": "module",
    "displayName": "Puristic Env Manager",
    "description": "Manage .env files against env.config schemas with validation, encryption, and a cross-service overview.",
    "publisher": "puristic",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/confederation.git",
        "directory": "_libs/vscode"
    },
    "main": "./dist/extension.cjs",
    "engines": {
        "vscode": "^1.96.0",
        "node": "24.14.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/env.config.{ts,mts,cts,js,mjs,cjs}"
    ],
    "contributes": {
        "customEditors": [
            {
                "viewType": "puristic.envEditor",
                "displayName": "Puristic Env Manager",
                "selector": [
                    {
                        "filenamePattern": ".env"
                    },
                    {
                        "filenamePattern": ".env.*"
                    }
                ],
                "priority": "default"
            }
        ],
        "commands": [
            {
                "command": "puristic.openEnvManager",
                "title": "Open Env Manager",
                "category": "Puristic"
            },
            {
                "command": "puristic.rescan",
                "title": "Re-scan Config & Env Files",
                "category": "Puristic"
            },
            {
                "command": "puristic.openAsPlainText",
                "title": "Open .env as Plain Text",
                "category": "Puristic"
            },
            {
                "command": "puristic.encryptAllSecrets",
                "title": "Encrypt All Plaintext Secrets",
                "category": "Puristic"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "puristic.openEnvManager",
                    "when": "puristic.isPuristicRepo"
                },
                {
                    "command": "puristic.rescan",
                    "when": "puristic.isPuristicRepo"
                },
                {
                    "command": "puristic.encryptAllSecrets",
                    "when": "puristic.isPuristicRepo"
                }
            ]
        },
        "configuration": {
            "title": "Puristic Env Manager",
            "properties": {
                "puristic.configFileGlob": {
                    "type": "string",
                    "default": "**/env.config.{ts,mts,cts,js,mjs,cjs}",
                    "description": "Glob used to discover env config definition files."
                },
                "puristic.envFileGlob": {
                    "type": "string",
                    "default": "**/.env*",
                    "description": "Glob used to discover .env files."
                },
                "puristic.exclude": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/node_modules/**",
                        "**/dist/**",
                        "**/.cache/**",
                        "**/.turbo/**",
                        "**/.git/**"
                    ],
                    "description": "Glob patterns excluded from discovery."
                },
                "puristic.nodePath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to a Node.js 24+ binary used to evaluate env.config files. Defaults to `node` on PATH."
                },
                "puristic.configHostTimeoutMs": {
                    "type": "number",
                    "default": 10000,
                    "description": "Timeout in milliseconds for a single config-host introspect/validate request."
                }
            }
        }
    },
    "scripts": {
        "build": "node esbuild.config.mjs && tsc -p tsconfig.json && tsc -p tsconfig.webview.json",
        "watch": "node esbuild.config.mjs --watch",
        "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.webview.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@puristic/env": "workspace:*",
        "@puristic/tsconfig": "workspace:*",
        "@types/node": "catalog:",
        "@types/vscode": "1.96.0",
        "@vscode/vsce": "catalog:",
        "esbuild": "catalog:",
        "tslib": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:",
        "zod": "catalog:"
    }
}
