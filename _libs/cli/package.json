{
    "name": "@puristic/env-cli",
    "version": "0.0.0",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/confederation.git",
        "directory": "_libs/cli"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "bin": {
        "puristic": "./dist/bin.js"
    },
    "exports": {
        "./bin.js": {
            "types": "./dist/bin.d.ts",
            "import": {
                "@puristic/src": "./src/bin.ts",
                "default": "./dist/bin.js"
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --build --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@puristic/env": "workspace:*",
        "@stricli/core": "catalog:",
        "tslib": "catalog:"
    },
    "devDependencies": {
        "@puristic/tsconfig": "workspace:*",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
