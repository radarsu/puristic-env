{
    "compilerOptions": {
        "baseUrl": "./",
        "composite": false,
        "declaration": false,
        "declarationMap": false,
        "sourceMap": false,
        "noEmit": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2024"],
        "types": ["node", "vscode"],
        "tsBuildInfoFile": "./.cache/tsbuildinfo"
    },
    "include": ["./src/**/*"],
    "exclude": ["./src/**/*.test.ts", "./src/webview/**/*"],
    "extends": "@puristic/tsconfig/tsconfig.base.json"
}
